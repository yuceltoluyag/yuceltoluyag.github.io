{
    "name": "minel-theme",
    "version": "1.0.0",
    "description": "Minimal Pelican theme with Tailwind CSS",
    "type": "commonjs",
    "engines": {
        "node": ">=16.0.0"
    },
    "scripts": {
        "css": "gulp styles",
        "js": "gulp scripts",
        "images": "gulp images",
        "build": "gulp",
        "watch": "gulp watch",
        "dev": "gulp watch",
        "prod": "cross-env NODE_ENV=production gulp",
        "manual": "npx @tailwindcss/cli -i _assets/css/input.css -o themes/Minel/static/css/style.min.css --watch"
    },
    "devDependencies": {
        "@babel/core": "^7.26.10",
        "@babel/preset-env": "^7.26.9",
        "@tailwindcss/cli": "^4.1.4",
        "@tailwindcss/postcss": "^4.1.4",
        "@tailwindcss/typography": "^0.5.16",
        "autoprefixer": "^10.4.21",
        "cross-env": "^7.0.3",
        "cssnano": "^7.0.6",
        "gulp": "^5.0.0",
        "gulp-babel": "^8.0.0",
        "gulp-clean-css": "^4.3.0",
        "gulp-imagemin": "^7.1.0",
        "gulp-postcss": "^10.0.0",
        "gulp-rename": "^2.0.0",
        "gulp-sourcemaps": "^3.0.0",
        "gulp-terser": "^2.1.0",
        "gulp-webp": "^4.0.1",
        "imagemin-mozjpeg": "^9.0.0",
        "imagemin-pngquant": "^9.0.2",
        "postcss": "^8.5.3",
        "postcss-cli": "^11.0.1",
        "postcss-import": "^16.1.0",
        "postcss-nesting": "^13.0.1",
        "postcss-preset-env": "^10.1.5",
        "tailwindcss": "^4.1.4",
        "vinyl-buffer": "^1.0.1"
    }
}
